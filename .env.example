# PostgreSQL connection string — pooled (used at runtime by the app)
DATABASE_URL=postgresql://user:password@host:5432/foodyz?sslmode=require

# Direct (non-pooled) connection string — used by Prisma migrations only
DIRECT_URL=postgresql://user:password@host:5432/foodyz?sslmode=require

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# Full base URL of the app
AUTH_URL=http://localhost:3000

# Vercel Blob — create a store at vercel.com/storage/blob, copy the read-write token
BLOB_READ_WRITE_TOKEN=

# Seed / E2E admin credentials
ADMIN_EMAIL=admin@foodyz.app
ADMIN_PASSWORD=
